TMDB_API_KEY=

# AI Recommendations (all optional — sensible defaults provided)
# Model runs 100% locally via ONNX Runtime — no API key required
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCH_SIZE=50

# Stripe (optional — subscription features)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=$4.9
STRIPE_PRICE_PREMIUM=$9.9
FRONTEND_URL=http://localhost:3000
